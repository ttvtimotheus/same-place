---
interface Props {
	index: number;
	title: string;
	body?: string;
}

const { index, title, body } = Astro.props;
const headingId = `step-title-${index}`;
---

<article class="step" data-step={index} aria-labelledby={headingId}>
	<div class="sr-only">
		<h2 id={headingId}>{title}</h2>
		{body && <p>{body}</p>}
	</div>
</article>