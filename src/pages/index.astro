---
import Map from '../components/Map.astro';
import Step from '../components/Step.astro';
import '../styles/global.css';

const steps = [
	{
		index: 0,
		title: 'Germany. Today.',
		body: 'The map opens on AfD vote share in 2025, with missing districts shown in grey.',
	},
	{
		index: 1,
		title: 'Has it always been like this?',
	},
	{
		index: 2,
		title: 'Germany. 1933.',
		body: 'The same districts transition to NSDAP vote share in March 1933 using the historical range.',
	},
	{
		index: 3,
		title: 'Then and now.',
		body: 'Drag the slider to compare the historical and contemporary regional pattern directly.',
	},
	{
		index: 4,
		title: "Some things change. Some things don't.",
		body: 'The final view shows the absolute gap between the normalised 1933 and 2025 shares across Germany.',
	},
];
---

<!doctype html>
<html lang="en-GB">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Same Place is a scrollytelling prototype exploring continuity in far-right support across Germany."
		/>
		<title>Same Place</title>
	</head>
	<body>
		<a class="skip-link" href="#main-content">Skip to main content</a>
		<main id="main-content" tabindex="-1">
			<section class="landing" aria-labelledby="page-title">
				<div class="landing__inner">
					<p class="landing__eyebrow">Same Place</p>
					<h1 id="page-title">This didn't start somewhere else.</h1>
					<p class="landing__subtitle">Scroll to explore.</p>
				</div>
			</section>

			<section class="story" aria-labelledby="story-heading">
				<h2 class="sr-only" id="story-heading">Scrollytelling narrative</h2>
				<Map />
				<div class="story__steps">
					{steps.map((step) => <Step {...step} />)}
				</div>
			</section>
		</main>
	</body>
</html>
